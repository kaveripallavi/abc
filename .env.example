# ============================================================================
# AI Resume Analyzer - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit actual .env files to version control
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://resumeanalyzer:password@localhost:5432/resumeanalyzer_dev

# Database Connection Pool
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ============================================================================
# Cache Configuration
# ============================================================================
# Redis Connection String
REDIS_URL=redis://localhost:6379

# Cache TTL (seconds)
CACHE_TTL_ANALYSIS=86400      # 24 hours
CACHE_TTL_RESUME=2592000      # 30 days
CACHE_TTL_EMBEDDINGS=31536000 # 1 year

# ============================================================================
# Authentication & Security
# ============================================================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRY=3600        # 1 hour (in seconds)
JWT_REFRESH_EXPIRY=604800  # 7 days (in seconds)

# Password Configuration
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_ROUNDS=10  # bcrypt rounds

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=10485760  # 10 MB in bytes
ALLOWED_FILE_TYPES=pdf,docx,txt

# AWS S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=resumeanalyzer-dev
S3_ENDPOINT=https://s3.amazonaws.com

# Local file storage (alternative to S3)
STORAGE_TYPE=s3  # or 'local' for development
LOCAL_STORAGE_PATH=./uploads

# ============================================================================
# LLM/AI Configuration
# ============================================================================
# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet

# Vector Embeddings
EMBEDDINGS_PROVIDER=openai  # or 'huggingface'
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSION=1536

# Vector Database
VECTOR_DB_PROVIDER=pinecone  # or 'weaviate'
PINECONE_API_KEY=your-api-key
PINECONE_INDEX_NAME=resumeanalyzer
PINECONE_ENVIRONMENT=production

# LLM Rate Limiting
LLM_RATE_LIMIT=100  # requests per minute
LLM_BATCH_SIZE=10   # batch requests for efficiency

# ============================================================================
# Payment Configuration
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription Pricing
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ============================================================================
# Email Configuration
# ============================================================================
SENDGRID_API_KEY=SG...
SENDGRID_FROM_EMAIL=noreply@resumeanalyzer.com
SENDGRID_FROM_NAME=Resume Analyzer

# Email Templates
EMAIL_TEMPLATE_WELCOME=d-...
EMAIL_TEMPLATE_ANALYSIS_READY=d-...
EMAIL_TEMPLATE_BATCH_COMPLETE=d-...

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=debug  # debug, info, warn, error
LOG_FORMAT=json  # json or text
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================================================
# Monitoring & Error Tracking
# ============================================================================
SENTRY_DSN=https://...@sentry.io/...
DATADOG_API_KEY=...
NEW_RELIC_LICENSE_KEY=...

# ============================================================================
# Job Queue Configuration
# ============================================================================
QUEUE_PROVIDER=bull  # or 'bree' for scheduled jobs
QUEUE_CONCURRENCY=5

# Job Timeouts (milliseconds)
JOB_TIMEOUT_PARSE=30000      # 30 seconds
JOB_TIMEOUT_ANALYZE=20000    # 20 seconds
JOB_TIMEOUT_MATCH=15000      # 15 seconds
JOB_TIMEOUT_BATCH=300000     # 5 minutes

# Job Retry Configuration
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY=5000  # milliseconds

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_BATCH_PROCESSING=true
ENABLE_RECRUITER_FEATURES=true
ENABLE_SKILL_GAP_ANALYSIS=true
ENABLE_ANALYTICS=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_WEBHOOKS=false

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW=60000  # milliseconds (1 minute)
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# Auth endpoints
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# Upload endpoints
RATE_LIMIT_UPLOAD_WINDOW=3600000  # 1 hour
RATE_LIMIT_UPLOAD_MAX_REQUESTS=10

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ============================================================================
# SECURITY
# ============================================================================
# DO NOT modify these in production unless instructed
SECURITY_HELMET_ENABLED=true
SECURITY_CSRF_ENABLED=true
SECURITY_RATE_LIMIT_ENABLED=true

# ============================================================================
# API Documentation
# ============================================================================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# ============================================================================
# Testing Configuration
# ============================================================================
# Only used during tests
TEST_DATABASE_URL=postgresql://resumeanalyzer:password@localhost:5432/resumeanalyzer_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_SEED_DATA=true

# ============================================================================
# Frontend Configuration (for backend API)
# ============================================================================
FRONTEND_URL=http://localhost:5173
FRONTEND_CALLBACK_URL=http://localhost:5173/auth/callback

# ============================================================================
# Scheduled Jobs
# ============================================================================
# Cron expressions for background tasks
JOB_CRON_CLEANUP_OLD_FILES=0 2 * * *  # 2 AM daily
JOB_CRON_DATABASE_BACKUP=0 3 * * *    # 3 AM daily
JOB_CRON_ANALYTICS_SYNC=0 */6 * * *   # Every 6 hours
JOB_CRON_CACHE_CLEANUP=0 4 * * *      # 4 AM daily

# ============================================================================
# Development Only
# ============================================================================
# Set to true to see detailed logs
DEBUG=*

# DANGEROUS: Only enable in development
ALLOW_RESET_DATABASE=false
SEED_TEST_DATA=false

# ============================================================================
# End of Configuration
# ============================================================================
